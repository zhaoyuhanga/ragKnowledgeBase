# ============================================================
# RAG 问答系统 - 环境变量配置文件
# 使用说明：将此文件复制为 .env 并填写实际值
# ============================================================

# ==================== 应用配置 ====================
# 应用环境: development | production
APP_ENV=development
# 应用主机地址
APP_HOST=0.0.0.0
# 应用端口
APP_PORT=8088
# 调试模式
DEBUG=true
# API 文档路径
API_V1_PREFIX=/api/v1
# 密钥（用于 JWT 等加密场景，请使用随机字符串）
SECRET_KEY=change-me-to-a-random-string-in-production
# JWT 算法
ALGORITHM=HS256
# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== MySQL 数据库配置 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rag_qa
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
# 连接池大小
MYSQL_POOL_SIZE=10
# 连接池最大溢出
MYSQL_MAX_OVERFLOW=20

# ==================== Redis 缓存配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Redis 键前缀
REDIS_KEY_PREFIX=rag_qa:
# 缓存默认过期时间（秒）
CACHE_DEFAULT_TTL=3600

# ==================== DeepSeek API 配置 ====================
# DeepSeek API 密钥（从 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=sk-your-api-key-here
# DeepSeek API 基础 URL
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 使用的模型名称
DEEPSEEK_MODEL=deepseek-v4-pro
# API 请求超时时间（秒）
DEEPSEEK_TIMEOUT=60
# 最大重试次数
DEEPSEEK_MAX_RETRIES=3

# ==================== Milvus 向量数据库配置 ====================
# Milvus 服务地址
MILVUS_HOST=localhost
MILVUS_PORT=19530
# Milvus 用户名（可选）
MILVUS_USER=
# Milvus 密码（可选）
MILVUS_PASSWORD=
# Collection 名称
MILVUS_COLLECTION_NAME=knowledge_base
# 索引类型: IVF_FLAT, HNSW, DISKANN 等
MILVUS_INDEX_TYPE=IVF_FLAT
# 度量类型: IP (内积), L2 (欧氏距离), COSINE (余弦)
MILVUS_METRIC_TYPE=IP
# nlist 参数
MILVUS_NLIST=1024

# ==================== Embedding 模型配置 ====================
# sentence-transformers 模型名称
EMBEDDING_MODEL=moka-ai/m3e-base
# 运行设备: cpu | cuda | mps
EMBEDDING_DEVICE=cpu
# 向量维度（m3e-base 为 768）
EMBEDDING_DIMENSION=768
# 批量处理大小
EMBEDDING_BATCH_SIZE=32

# ==================== 文本切分配置 ====================
# 文本块最大字符数
CHUNK_SIZE=500
# 文本块重叠字符数
CHUNK_OVERLAP=50
# 最小块字符数（过滤过短块）
CHUNK_MIN_SIZE=50

# ==================== 向量检索配置 ====================
# 检索返回的最相关文档数量
RETRIEVAL_TOP_K=5
# 相似度阈值（低于此值的检索结果将被过滤）
SIMILARITY_THRESHOLD=0.5
# 是否启用多路召回
ENABLE_MMR=false
# MMR diversity 参数（仅在启用 MMR 时生效）
MMR_DIVERSITY=0.5

# ==================== 文件上传配置 ====================
# 文档存储目录
UPLOAD_DIR=./data/documents
# 允许的文件扩展名
ALLOWED_EXTENSIONS=pdf,md,txt,docx
# 单文件最大大小（字节）
MAX_FILE_SIZE=10485760
# 同时处理的最大文件数
MAX_CONCURRENT_UPLOADS=5

# ==================== 日志配置 ====================
# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# 日志格式
LOG_FORMAT=json
# 日志文件路径
LOG_FILE_PATH=./logs/rag_qa.log
# 日志文件最大大小（字节）
LOG_FILE_MAX_SIZE=10485760
# 日志文件保留数量
LOG_FILE_BACKUP_COUNT=5
# 是否在控制台输出日志
LOG_CONSOLE=true

# ==================== CORS 跨域配置 ====================
# 允许的来源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
# 是否允许凭据
CORS_ALLOW_CREDENTIALS=true
# 允许的 HTTP 方法
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
# 允许的 HTTP 头
CORS_ALLOW_HEADERS=*
