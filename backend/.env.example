# 应用环境
APP_ENV=local

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=3308
DATABASE_NAME=rag_db
DATABASE_USERNAME=root
DATABASE_PASSWORD=123456

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
